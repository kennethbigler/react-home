    "test:no-watch": "vitest run",
    "test:coverage": "NODE_V8_COVERAGE=codecov_reports vitest run --coverage",
    "deploy": "./scripts/deploy.sh",
    "deploy:no-fetch": "SKIP_BOTC_FETCH=1 ./scripts/deploy.sh",
    "analyze": "./scripts/analyze.sh",
    "dead-code": "npx -y knip",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix --report-unused-disable-directives",
    "lint:q": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix --quiet",
    "fetch-botc-scripts": "node scripts/fetch-botc-scripts.mjs"
  },
