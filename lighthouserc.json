{
  "ci": {
    "collect": {
      "staticDistDir": "./dist"
    },
    "upload": {
      "target": "temporary-public-storage"
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "deprecations": "warn",
        "errors-in-console": "warn",
        "network-dependency-tree-insight": "warn",
        "third-party-cookies": "warn",
        "unused-javascript": "warn"
      }
    }
  }
}
